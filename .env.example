# === EDU-PUBLISH Environment Variables ===
# Copy this file to .env and fill in the values.
# All storage/database variables are OPTIONAL — the build works without them.

# --- Site ---
SITE_URL=https://example.edu.cn

# --- S3-compatible Object Storage (optional, for large attachments / media CDN) ---
# Works with ANY S3-compatible provider: AWS S3, Cloudflare R2, MinIO, Backblaze B2, etc.
# If omitted, all assets are served directly from the static build output.
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
ATTACHMENT_UPLOAD_THRESHOLD_MB=20

# --- Cloudflare Pages (optional, only needed for wrangler CLI deploy) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PROJECT_NAME=

# --- View counts (optional) ---
# The site works without any database. View counting is pluggable via ViewStore interface.
# Currently supported: D1 (Cloudflare). See functions/lib/view-store.ts for extensibility.
VIEW_COUNT_BACKEND=none          # none | d1
CF_D1_DATABASE_ID=

# --- Automation stack (optional) ---
NAPCAT_ACCOUNT=
ASTRBOT_DASHBOARD_PORT=6185
OPENCLAW_WORKSPACE=/opt/edu-publish
